{
  "name": "prc",
  "version": "1.0.0",
  "description": "jiuse🛒 Retail Price Comparison Bot A smart bot that compares product prices across multiple e-commerce platforms and helps users find the best deals in real-time. 🚀 Features",
  "main": "index.js",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n \"SERVER,CLIENT\" -c \"blue,green\" \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "install:all": "npm install",
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=client"
  },
